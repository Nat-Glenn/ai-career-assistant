# Server-side only — never expose to the browser (no NEXT_PUBLIC_ prefix).
OPENAI_API_KEY=sk-your-key-here

# Optional — Adzuna Jobs API (https://developer.adzuna.com/)
# When set, job discovery also searches Adzuna in addition to RemoteOK.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# ISO country code for Adzuna search (default: us). Examples: us, gb, ca, au
ADZUNA_COUNTRY=us

# Optional — JSearch / RapidAPI Jobs (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
# Broad job search source for many industries. Server-side only.
RAPIDAPI_KEY=
JSEARCH_RAPIDAPI_HOST=jsearch.p.rapidapi.com
